{
  "name": "prompt-forge-pro",
  "version": "1.0.0",
  "description": "AI prompt engineering tool that lives in the Windows system tray",
  "license": "BUSL-1.1",
  "main": "electron/main.js",
  "scripts": {
    "postinstall": "node scripts/create-icon.js",
    "dev": "concurrently -k -n VITE,ELECTRON -c cyan,magenta \"cross-env NODE_ENV=development vite\" \"wait-on tcp:5173 && cross-env NODE_ENV=development electron .\"",
    "build": "vite build && electron-builder",
    "release": "vite build && electron-builder --publish always",
    "start": "electron .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "build": {
    "appId": "com.promptforge.app",
    "productName": "PromptForge",
    "copyright": "Copyright © 2026 519lab.com, a registered trade name of Onward Investment LLC",
    "publish": [
      {
        "provider": "github",
        "owner": "ggrace519",
        "repo": "prompt-forge"
      }
    ],
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "assets/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/tray-icon.png",
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": false,
      "createStartMenuShortcut": true,
      "shortcutName": "PromptForge",
      "license": "LICENSE"
    },
    "extraMetadata": {
      "main": "electron/main.js"
    }
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.128",
    "@anthropic-ai/sdk": "^0.106.0",
    "axios": "^1.14.0",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.8.9",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "overrides": {
    "esbuild": "0.28.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^5.0.0",
    "@vitest/coverage-v8": "^3.0.0",
    "concurrently": "^9.0.0",
    "cross-env": "^7.0.3",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "jsdom": "^26.0.0",
    "vite": "^8.0.2",
    "vitest": "^3.0.0",
    "wait-on": "^8.0.0"
  }
}
